# Server
PORT=3000

# Supabase (from your Supabase project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
SUPABASE_STORAGE_BUCKET=beer-photos

# Sign in with Apple
# Your iOS app bundle id, used as the audience claim when verifying Apple identity tokens
APPLE_BUNDLE_ID=com.example.BeerTracker

# Backend session JWT
# Random long string (>= 32 chars). Used to sign session JWTs returned to the iOS app.
SESSION_JWT_SECRET=replace_me_with_a_long_random_string
SESSION_JWT_EXPIRES_IN=30d
